{
  "name": "minimal-sessions",
  "productName": "Minimal Sessions",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "description": "A minimal desktop client for running multiple Claude coding sessions in parallel, each scoped to a working folder and model.",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "predev": "node scripts/rebuild-native.mjs --runtime=electron",
    "dev": "electron-vite dev",
    "prebuild": "node scripts/rebuild-native.mjs --runtime=electron",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "pretest": "node scripts/rebuild-native.mjs --runtime=node",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "rebuild:electron": "node scripts/rebuild-native.mjs --runtime=electron",
    "rebuild:node": "node scripts/rebuild-native.mjs --runtime=node",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:win": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.minimalsessions.app",
    "productName": "Minimal Sessions",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "hamzaalomari",
        "repo": "minimal-sessions"
      }
    ],
    "extraResources": [
      {
        "from": "resources/commands",
        "to": "commands",
        "filter": ["**/*.md"]
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-pty/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.170",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "ansi_up": "^6.0.6",
    "better-sqlite3": "^12.10.0",
    "electron-updater": "^6.3.9",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.1.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^33.3.1",
    "electron-builder": "^26.15.2",
    "electron-vite": "^2.3.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
