{
  "extends": "./tsconfig.web.json",
  "compilerOptions": {
    "types": ["vitest/globals", "@testing-library/jest-dom", "node"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/shared/**/*.ts",
    "src/main/db.ts",
    "src/main/fs.ts",
    "src/main/chat.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "test/**/*.ts",
    "vitest.config.ts"
  ]
}
